+    //Trace("win_lbr_chartabsize 2: %s, cts->cts_vcol=%d\n", profile_msg(&tm), cts->cts_vcol);
     return size;
 #endif
 }
@@ -1732,6 +1746,9 @@ getvcol(
     static colnr_T  saved_vcol = 0;
     static int	    old_cond = 0;
 
+    proftime_T tm;
+    profile_start(&tm);
+    Trace("getvcol");
     vcol = 0;
     line = ptr = ml_get_buf(wp->w_buffer, pos->lnum, FALSE);
 
@@ -1757,6 +1774,7 @@ getvcol(
 #endif
        )
     {
+	Trace("getvcol 1");
 	if (0 && s_vcol_cache_valid2
 		&& (old_win != NULL) && (old_win == wp)
 		&& (old_line != NULL) && (old_line == line)
@@ -1832,6 +1850,7 @@ getvcol(
     }
     else
     {
+	Trace("getvcol 2");
 	if (0 && s_vcol_cache_valid2
 		&& (old_win != NULL) && (old_win == wp)
 		&& (old_line != NULL) && (old_line == line)
@@ -1966,6 +1985,7 @@ getvvcol(
     colnr_T	endadd;
     char_u	*ptr;
 
+    Trace("getvvcol");
     if (virtual_active())
     {
 	// For virtual mode, only want one value
@@ -1998,6 +2018,7 @@ getvvcol(
     }
     else
 	getvcol(wp, pos, start, cursor, end, flags);
+    Trace("getvvcol end");
 }
 
 /*
diff --git a/src/misc1.c b/src/misc1.c
index cc27ced20..494c6c771 100644
--- a/src/misc1.c
+++ b/src/misc1.c
@@ -408,6 +408,8 @@ plines_win_nofold(win_T *wp, linenr_T lnum)
     colnr_T	len;
     chartabsize_T cts;
 
+    proftime_T tm;
+    profile_start(&tm);
     s = ml_get_buf(wp->w_buffer, lnum, FALSE);
     len = ml_get_buf_len(wp->w_buffer, lnum);
     init_chartabsize_arg_len(&cts, wp, lnum, 0, s, s, len);
@@ -436,6 +438,8 @@ plines_win_nofold(win_T *wp, linenr_T lnum)
 	return 1;
     col -= width;
     width += win_col_off2(wp);
+    profile_end(&tm);
+    Trace("plines_win_nofold end, %s", profile_msg(&tm));
     return (col + (width - 1)) / width + 1;
 }
 
diff --git a/src/move.c b/src/move.c
index 1e3be9206..87a6b39d5 100644
--- a/src/move.c
+++ b/src/move.c
@@ -322,9 +322,13 @@ update_topline(void)
     int		save_so = *so_ptr;
     bool	eof_pressure;
 
+    Trace("update_topline");
     // Cursor is updated instead when this is TRUE for 'splitkeep'.
     if (skip_update_topline)
+    {
+	Trace("update_topline end1");
 	return;
+    }
 
     // If there is no valid screen and when the window height is zero just use
     // the cursor line.
@@ -334,12 +338,16 @@ update_topline(void)
 	curwin->w_topline = curwin->w_cursor.lnum;
 	curwin->w_botline = curwin->w_topline;
 	curwin->w_scbind_pos = 1;
+	Trace("update_topline end2");
 	return;
     }
 
     check_cursor_moved(curwin);
     if (curwin->w_valid & VALID_TOPLINE)
+    {
+	Trace("update_topline end3");
 	return;
+    }
 
     // When dragging with the mouse, don't scroll that quickly
     if (mouse_dragging > 0)
@@ -581,6 +589,7 @@ update_topline(void)
     }
 
     *so_ptr = save_so;
+    Trace("update_topline end");
 }
 
 /*
@@ -896,10 +905,12 @@ cursor_valid(void)
     void
 validate_cursor(void)
 {
+    Trace("validate_cursor");
     check_cursor_lnum();
     check_cursor_moved(curwin);
     if ((curwin->w_valid & (VALID_WCOL|VALID_WROW)) != (VALID_WCOL|VALID_WROW))
 	curs_columns(TRUE);
+    Trace("validate_cursor end");
 }
 
 #if defined(FEAT_GUI)
@@ -934,6 +945,7 @@ curs_rows(win_T *wp)
     long	fold_count;
 #endif
 
+    Trace("curs_rows: wp->w_cline_row=%d, wp->w_cline_height=%d", wp->w_cline_row, wp->w_cline_height);
     // Check if wp->w_lines[].wl_size is invalid
     all_invalid = (!redrawing()
 			|| wp->w_lines_valid == 0
@@ -1040,6 +1052,7 @@ curs_rows(win_T *wp)
 
     redraw_for_cursorline(curwin);
     wp->w_valid |= VALID_CROW|VALID_CHEIGHT;
+    Trace("curs_rows end: wp->w_cline_row=%d, wp->w_cline_height=%d", wp->w_cline_row, wp->w_cline_height);
 }
 
 /*
@@ -1201,6 +1214,9 @@ curs_columns(
     long	siso = get_sidescrolloff_value();
     int		did_sub_skipcol = FALSE;
 
+    proftime_T tm;
+    Trace("curs_columns: curwin->w_wcol=%d curwin->w_virtcol=%d", curwin->w_wcol, curwin->w_virtcol);
+    profile_start(&tm);
     /*
      * First make sure that w_topline is valid (after moving the cursor).
      */
@@ -1217,6 +1233,9 @@ curs_columns(
     curwin->w_virtcol_first_char = 0;
 #endif
 
+    profile_end(&tm);
+    Trace("curs_columns 1: before getvvcol(), %s", profile_msg(&tm));
+    profile_start(&tm);
     /*
      * Compute the number of virtual columns.
      */
@@ -1236,6 +1255,9 @@ curs_columns(
     extra = curwin_col_off();
     curwin->w_wcol = curwin->w_virtcol + extra;
     endcol += extra;
+    profile_end(&tm);
+    Trace("curs_columns 2: after curwin_col_off(), %s", profile_msg(&tm));
+    profile_start(&tm);
 
     /*
      * Now compute w_wrow, counting screen lines from w_cline_row.
@@ -1358,6 +1380,9 @@ curs_columns(
     else
 	curwin->w_wrow += diff_check_fill(curwin, curwin->w_cursor.lnum);
 #endif
+    profile_end(&tm);
+    Trace("curs_columns 3, %s", profile_msg(&tm));
+    profile_start(&tm);
 
     prev_skipcol = curwin->w_skipcol;
 
@@ -1379,6 +1404,9 @@ curs_columns(
 	    && width2 > 0
 	    && curwin->w_width != 0)
     {
+	profile_end(&tm);
+	Trace("curs_columns 4, %s", profile_msg(&tm));
+	profile_start(&tm);
 	// Cursor past end of screen.  Happens with a single line that does
 	// not fit on screen.  Find a skipcol to show the text around the
 	// cursor.  Avoid scrolling all the time. compute value of "extra":
@@ -1457,11 +1485,16 @@ curs_columns(
 	    win_ins_lines(curwin, 0, extra, FALSE, FALSE);
 	else if (extra < 0)
 	    win_del_lines(curwin, 0, -extra, FALSE, FALSE, 0);
+	profile_end(&tm);
+	Trace("curs_columns 5, %s", profile_msg(&tm));
+	profile_start(&tm);
     }
     else if (!curwin->w_p_sms)
 	curwin->w_skipcol = 0;
     if (prev_skipcol != curwin->w_skipcol)
 	redraw_later(UPD_SOME_VALID);
+    profile_end(&tm);
+    Trace("curs_columns 6, %s", profile_msg(&tm));
 
 #ifdef FEAT_SYN_HL
     redraw_for_cursorcolumn(curwin);
@@ -1483,6 +1516,7 @@ curs_columns(
     curwin->w_valid_skipcol = curwin->w_skipcol;
 
     curwin->w_valid |= VALID_WCOL|VALID_WROW|VALID_VIRTCOL;
+    Trace("curs_columns end: curwin->w_wcol=%d curwin->w_virtcol=%d", curwin->w_wcol, curwin->w_virtcol);
 }
 
 #if defined(FEAT_EVAL) || defined(FEAT_PROP_POPUP)
