     cts->cts_with_trailing = len == MAXCOL;
 #endif
@@ -1329,6 +1333,9 @@ win_lbr_chartabsize(
     int		no_sbr = FALSE;
 #endif
 
+    proftime_T tm;
+    //Trace("win_lbr_chartabsize: cts->cts_line=%p cts->cts_ptr=%p cts->cts_vcol=%d\n", cts->cts_line, cts->cts_ptr, cts->cts_vcol);
+    profile_start(&tm);
 #if defined(FEAT_PROP_POPUP)
     cts->cts_cur_text_width = 0;
     cts->cts_first_char = 0;
@@ -1350,7 +1357,12 @@ win_lbr_chartabsize(
 #endif
     {
 	if (wp->w_p_wrap)
-	    return win_nolbr_chartabsize(cts, headp);
