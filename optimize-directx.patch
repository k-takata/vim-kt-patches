+/*
+ * out_flush_cursor(): flush the output buffer and redraw the cursor
+ */
+    void
+out_flush_cursor(
+    int		force,		/* when TRUE, update even when not moved */
+    int		clear_selection)/* clear selection under cursor */
+{
+#ifdef FEAT_GUI
+    gui_disable_flush();
+#endif
+    out_flush();
+#ifdef FEAT_GUI
+    gui_enable_flush();
+    if (gui.in_use)
+    {
+	gui_update_cursor(force, clear_selection);
+	gui_may_flush();
+    }
+#endif
+}
