diff --git a/src/testdir/test_stat.in b/src/testdir/test_stat.in
new file mode 100644
--- /dev/null
+++ b/src/testdir/test_stat.in
@@ -0,0 +1,48 @@
+Tests for stat functions and checktime     vim: set ft=vim :
+
+STARTTEST
+:so small.vim
+:bwipe!
+:w! test.out
+:let fname='Xtest.tmp'
+:let ts=localtime()
+:sleep 1
+:let fl=['Hello World!']
+:call writefile(fl, fname)
+:let tf=getftime(fname)
+:sleep 1
+:let te=localtime()
+:$put ='Existent file:'
+:"$put =ts
+:"$put =tf
+:"$put =te
+:$put ='getftime: ' . ((ts <= tf && tf <= te) ? 1 : 0)
+:$put ='getfsize: ' . getfsize(fname)
+:$put ='getftype: ' . getftype(fname)
+:$put ='getfperm: ' . getfperm(fname)[0:2]
+:$put ='Existent directory:'
+:$put ='getfsize: ' . getfsize('.')
+:$put ='getftype: ' . getftype('.')
+:$put ='getfperm: ' . getfperm('.')[0:2]
+:$put ='Test for checktime:'
+:w
+:set autoread
+:exec 'e' fname
+:sleep 2
+:let fl=readfile(fname)
+:let fl[0] .= ' - checktime'
+:call writefile(fl, fname)
+:checktime
+:y a
+:bp!
+:$put a
+:call delete(fname)
+:$put ='Nonexistent file:'
+:$put ='getftime: ' . getftime(fname)
+:$put ='getfsize: ' . getfsize(fname)
+:$put ='getftype: ' . getftype(fname)
+:$put ='getfperm: ' . getfperm(fname)
+:w
+:qa!
+ENDTEST
+
