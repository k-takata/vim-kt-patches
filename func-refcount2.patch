+
+/*
+ * Unref "callback" and "partial" retured by get_callback().
+ */
+    void
+free_callback(char_u *callback, partial_T *partial)
+{
+    if (partial == NULL)
+	func_unref(callback);
+    else
+	partial_unref(partial);
+}
