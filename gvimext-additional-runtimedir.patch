+
+    // remove "gvim.exe" from the end
+    for (idx = (int)strlen(buf) - 1; idx >= 0; idx--)
+	if (buf[idx] == '\\' || buf[idx] == '/')
+	{
+	    buf[++idx] = 0;
+	    break;
+	}
+
+    // Check the existence of defaults.vim
+    char *p = buf + idx;
+    strcpy(p, "defaults.vim");
+    if (FileExists(buf))
+    {
+	*p = 0;		// Cut "defaults.vim"
