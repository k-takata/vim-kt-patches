 		break;
 
-	    if (s_use_vcol_cache
-		    && (ptr > line)
+	    if ((ptr > line)
 		    && (ptr - line <= col_save)
 		    && (next_ptr - line >= col_save))
 	    {
@@ -1863,8 +1838,7 @@ getvcol(
 	    if (next_ptr - line > pos->col) // character at pos->col
 		break;
 
-	    if (s_use_vcol_cache
-		    && (cts.cts_ptr > line)
+	    if ((cts.cts_ptr > line)
 		    && (cts.cts_ptr - line <= col_save)
 		    && (next_ptr - line >= col_save)
