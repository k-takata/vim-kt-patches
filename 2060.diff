+    FillConsoleOutputCharacter(g_hConOut, ' ', n, coord, &dwDummy);
+    FillConsoleOutputAttribute(g_hConOut, 0, n, coord, &dwDummy);
+}
+
+    static void
+hub_set_scroll_region(
+    unsigned left,
+    unsigned top,
+    unsigned right,
+    unsigned bottom)
+{
+    if (USE_VCON)
+	vcon_set_scroll_region(left, top, right, bottom);
+    else
+	set_scroll_region(left, top, right, bottom);
+}
+
+    static void
+vcon_set_scroll_region(
+    unsigned left,
+    unsigned top,
+    unsigned right,
+    unsigned bottom)
+{
+    if (left >= right
+	    || top >= bottom
+	    || right > (unsigned) Columns - 1
+	    || bottom > (unsigned) Rows - 1)
+	return;
+
+    g_srScrollRegion.Left =   left;
+    g_srScrollRegion.Top =    top;
+    g_srScrollRegion.Right =  right;
+    g_srScrollRegion.Bottom = bottom;
+
+    vcon_printf("\033[%d;%dr", top + 1, bottom + 1);
+}
+
+    static void
+vcon_insert_lines(
+    unsigned cLines)
+{
+    SMALL_RECT	source;
+    COORD	dest, coord;
+
+    dest.X = 0;
+    dest.Y = g_coord.Y + cLines;
+
+    source.Left   = 0;
+    source.Top    = g_coord.Y;
+    source.Right  = g_srScrollRegion.Right;
+    source.Bottom = g_srScrollRegion.Bottom - cLines;
+
+    set_console_color_rgb();
+
+    vcon_gotoxy(1, source.Top + 1);
+    vcon_printf("\033[%dT", cLines);
+
+    if (source.Bottom < dest.Y)
+    {
+	coord.X = 0;
+	coord.Y = source.Bottom;
+	vcon_clear_chars(coord, Columns * (dest.Y - source.Bottom));
+    }
+}
+
+    static void
+vcon_delete_lines(
+    unsigned cLines)
+{
+    SMALL_RECT	source;
+    COORD	dest, coord;
+    int		nb;
+
+    dest.X = 0;
+    dest.Y = g_coord.Y;
+
+    source.Left   = 0;
+    source.Top    = g_coord.Y + cLines;
+    source.Right  = g_srScrollRegion.Right;
+    source.Bottom = g_srScrollRegion.Bottom;
+
+    set_console_color_rgb();
+
+    vcon_gotoxy(1, source.Top + 1);
+    vcon_printf("\033[%dS", cLines);
+
+    nb = dest.Y + (source.Bottom - source.Top) + 1;
+
+    if (nb < source.Top)
+    {
+	coord.X = 0;
+	coord.Y = nb;
+	vcon_clear_chars(coord, Columns * (source.Top - nb));
+    }
+}
+
+    static void
+vcon_visual_bell(
+    void)
+{
+    COORD   coordOrigin = {0, 0};
+    WORD    attrFlash = ~g_attrCurrent & 0xff;
+
+    DWORD   dwDummy;
+
+    FillConsoleOutputAttribute(g_hConOut, attrFlash, Rows * Columns,
+			       coordOrigin, &dwDummy);
+
+    Sleep((1000 / 60) * 2); /* 2 frame in many environments */
+
+    /* restore by caller */
+}
+
+    static DWORD
+hub_write_chars(
+    char_u *pchBuf,
+    DWORD  cbToWrite)
+{
+    if (USE_VCON)
+	return vcon_write_chars(pchBuf, cbToWrite);
+    else
+	return write_chars(pchBuf, cbToWrite);
+}
+
+    static DWORD
+vcon_write_chars(
+    char_u *pchBuf,
+    DWORD  cbToWrite)
+{
+    DWORD written;
+
+#ifdef FEAT_MBYTE
+    if (enc_codepage >= 0 && (int)GetACP() != enc_codepage)
+    {
+	static WCHAR	*unicodebuf = NULL;
+	static int	unibuflen = 0;
+	int		length;
+	DWORD		n, cchwritten, cells;
+
+	length = MultiByteToWideChar(CP_UTF8, 0, (LPCSTR)pchBuf, cbToWrite, 0, 0);
+	if (unicodebuf == NULL || length > unibuflen)
+	{
+	    vim_free(unicodebuf);
+	    unicodebuf = (WCHAR *)lalloc(length * sizeof(WCHAR), FALSE);
+	    unibuflen = length;
+	}
+	MultiByteToWideChar(CP_UTF8, 0, (LPCSTR)pchBuf, cbToWrite,
+			    unicodebuf, unibuflen);
+
+	cells = mb_string2cells(pchBuf, cbToWrite);
+
+	if (WriteConsoleW(g_hConOut, unicodebuf, length, &cchwritten,
+		NULL) == 0 || cchwritten == 0)
+	    cchwritten = 1;
+
+	if (cchwritten == length)
+	{
+	    written = cbToWrite;
+	    g_coord.X += (SHORT)cells;
+	}
+	else
+	{
+	    char_u *p = pchBuf;
+	    for (n = 0; n < cchwritten; n++)
+		MB_CPTR_ADV(p);
+	    written = p - pchBuf;
+	    g_coord.X += (SHORT)mb_string2cells(pchBuf, written);
+	}
+    }
+    else
+#endif
+    {
+	if (WriteConsole(g_hConOut, (LPCSTR)pchBuf, cbToWrite, &written,
+		NULL) == 0 || written == 0)
+	    written = 1;
+
+	g_coord.X += (SHORT) written;
+    }
+
+    while (g_coord.X > g_srScrollRegion.Right)
+    {
+	g_coord.X -= (SHORT) Columns;
+	if (g_coord.Y < g_srScrollRegion.Bottom)
+	    g_coord.Y++;
+    }
+
+    vcon_gotoxy(g_coord.X + 1, g_coord.Y + 1);
+
+    return written;
+}
+
