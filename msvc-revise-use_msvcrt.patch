diff --git a/src/Make_mvc.mak b/src/Make_mvc.mak
--- a/src/Make_mvc.mak
+++ b/src/Make_mvc.mak
@@ -479,9 +479,17 @@ DIRECTX_OBJ	= $(OUTDIR)\gui_dwrite.obj
 
 # Only allow XPM for a GUI build.
 ! ifndef XPM
-!  ifndef USE_MSVCRT
-# Both XPM and USE_MSVCRT are not set, use the included xpm files, depending
-# on the architecture.
+# If XPM is not set, use the included xpm files, depending on the CRT and the
+# architecture.
+!  ifdef USE_MSVCRT
+!   if "$(CPU)" == "AMD64"
+XPM = xpm\vcrt-x64
+!   elseif "$(CPU)" == "i386"
+XPM = xpm\vcrt-x86
+!   else
+XPM = no
+!   endif
+!  else # USE_MSVCRT
 !   if "$(CPU)" == "AMD64"
 XPM = xpm\x64
 !   elseif "$(CPU)" == "ARM64"
@@ -491,8 +499,6 @@ XPM = xpm\x86
 !   else
 XPM = no
 !   endif
-!  else # USE_MSVCRT
-XPM = no
 !  endif # USE_MSVCRT
 ! endif # XPM
 ! if "$(XPM)" != "no"
@@ -806,7 +812,7 @@ EXECFLAGS =
 EXELIBC = $(LIBC)
 ! else
 EXECFLAGS = -DUSE_OWNSTARTUP /GS-
-EXELIBC =
+EXELIBC = /nodefaultlib
 ! endif
 !else
 OBJ = $(OBJ) $(OUTDIR)\os_w32exe.obj $(OUTDIR)\vim.res
