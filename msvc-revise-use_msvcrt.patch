MSVC: Revise USE_MSVCRT

From: K.Takata <kentkt@csc.jp>

Signed-off-by: K.Takata <kentkt@csc.jp>
---
 src/Make_mvc.mak                     |   18 ++++++++++++------
 src/xpm/vcrt-x64/lib-vc14/libXpm.lib |  Bin
 src/xpm/vcrt-x86/lib-vc14/libXpm.lib |  Bin
 3 files changed, 12 insertions(+), 6 deletions(-)
 create mode 100644 src/xpm/vcrt-x64/lib-vc14/libXpm.lib
 create mode 100644 src/xpm/vcrt-x86/lib-vc14/libXpm.lib

diff --git a/src/Make_mvc.mak b/src/Make_mvc.mak
index 71fd5796b..9d52816ba 100644
--- a/src/Make_mvc.mak
+++ b/src/Make_mvc.mak
@@ -469,9 +469,17 @@ DIRECTX_OBJ = $(OUTDIR)\gui_dwrite.obj
 
 # Only allow XPM for a GUI build.
 ! IFNDEF XPM
-!  IFNDEF USE_MSVCRT
-# Both XPM and USE_MSVCRT are not set, use the included xpm files, depending
-# on the architecture.
+# If XPM is not set, use the included xpm files, depending on the CRT and the
+# architecture.
+!  IFDEF USE_MSVCRT
+!   IF "$(CPU)" == "AMD64"
+XPM = xpm\vcrt-x64
+!   ELSEIF "$(CPU)" == "i386"
+XPM = xpm\vcrt-x86
+!   ELSE
+XPM = no
+!   ENDIF
+!  ELSE # USE_MSVCRT
 !   IF "$(CPU)" == "AMD64"
 XPM = xpm\x64
 !   ELSEIF "$(CPU)" == "ARM64"
@@ -481,8 +489,6 @@ XPM = xpm\x86
 !   ELSE
 XPM = no
 !   ENDIF
-!  ELSE # USE_MSVCRT
-XPM = no
 !  ENDIF # USE_MSVCRT
 ! ENDIF # XPM
 ! IF "$(XPM)" != "no"
@@ -819,7 +825,7 @@ EXECFLAGS =
 EXELIBC = $(LIBC)
 ! ELSE
 EXECFLAGS = -DUSE_OWNSTARTUP /GS-
-EXELIBC =
+EXELIBC = /nodefaultlib
 ! ENDIF
 !ELSE
 OBJ = $(OBJ) $(OUTDIR)\os_w32exe.obj $(OUTDIR)\vim.res
