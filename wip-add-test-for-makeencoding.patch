+" Tests for 'makeencoding', 'errfileencoding' and 'grepencoding'.
+if !has('multi_byte')
+  finish
+endif
+
+source shared.vim
+
+let s:python = PythonProg()
+if s:python == ''
+  " Can't run this test.
+  finish
+endif
+
+
+let s:message_tbl = {
+      \ 'utf-8': 'ÀÈÌÒÙ こんにちは',
+      \ 'latin1': 'ÀÈÌÒÙ',
+      \ 'cp932': 'こんにちは',
+      \}
+
+
+func Test_makeencoding()
+  let &makeprg = s:python
+  set errorformat=%f(%l)\ :\ %m
+
+  for enc in keys(s:message_tbl)
+    let &makeencoding = enc
+    exec "silent make! test_makeencoding.py " . enc
+    copen
+    call assert_equal("Xfoobar.c|10| " . s:message_tbl[enc] . " (" . enc . ")",
+          \ getline('.'))
+    cclose
+  endfor
+endfunc
