+#endif
+    gui_init_font(*p_guifont == NUL ? hl_get_font_name() : p_guifont, FALSE);
+    gui_mswin_get_menu_height(FALSE);
+    InvalidateRect(hwnd, NULL, TRUE);
+    s_in_dpichanged = FALSE;
+    return 0L;
+}
 
 
