+static BOOL		s_in_dpichanged = FALSE;
+
+static UINT (WINAPI *pGetDpiForSystem)(void) = NULL;
+static UINT (WINAPI *pGetDpiForWindow)(HWND hwnd) = NULL;
+static int (WINAPI *pGetSystemMetricsForDpi)(int, UINT) = NULL;
+//static INT (WINAPI *pGetWindowDpiAwarenessContext)(HWND hwnd) = NULL;
+static DPI_AWARENESS_CONTEXT (WINAPI *pSetThreadDpiAwarenessContext)(DPI_AWARENESS_CONTEXT dpiContext) = NULL;
+static BOOL (WINAPI *pSystemParametersInfoForDpiW)(UINT, UINT, PVOID, UINT, UINT) = NULL;
+
+    static int
+vimGetDpiForSystem(void)
+{
+    if (pGetDpiForSystem != NULL)
+    {
+	return pGetDpiForSystem();
+    }
+    return DEFAULT_DPI;
+}
+
+    static int
+vimSystemParametersInfoForDpiW(UINT uiAction, UINT uiParam, PVOID pvParam,
+	UINT fwWinIni, UINT dpi)
+{
+    if (pSystemParametersInfoForDpiW != NULL)
+    {
+	return pSystemParametersInfoForDpiW(uiAction, uiParam, pvParam,
+		fwWinIni, dpi);
+    }
+    return SystemParametersInfoW(uiAction, uiParam, pvParam, fwWinIni);
+}
+
+    static int
+vimGetSystemMetricsForDpi(int nIndex, UINT dpi)
+{
+    if (pGetSystemMetricsForDpi != NULL)
+    {
+	return pGetSystemMetricsForDpi(nIndex, dpi);
+    }
+    return GetSystemMetrics(nIndex);
+}
