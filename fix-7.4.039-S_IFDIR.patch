 	    n = _fstat(fd, (struct _stat*)stp);
+	    if ((n == 0) && (attr & FILE_ATTRIBUTE_DIRECTORY))
+		stp->st_mode = (stp->st_mode & ~S_IFREG) | S_IFDIR;
 	    _close(fd);
 	    return n;
 	}
     }
-#endif
     return stat(name, stp);
 }
 
@@ -549,12 +552,14 @@ stat_symlink_aware(const char *name, str
