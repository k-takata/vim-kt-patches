+		    (un == UVARNUM_MAX / 16 && digit <= UVARNUM_MAX % 16))
+		un = 16 * un + digit;
 	    else
 		un = UVARNUM_MAX;
 	    ++ptr;
@@ -1974,9 +1980,11 @@ vim_str2nr(
 	/* decimal */
 	while (VIM_ISDIGIT(*ptr))
 	{
+	    uvarnumber_T    digit = (uvarnumber_T)(*ptr - '0');
