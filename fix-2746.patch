+	    uvarnumber_T    digit = (uvarnumber_T)(*ptr - '0');
 	    /* avoid ubsan error for overflow */
-	    if (un < UVARNUM_MAX / 8)
-		un = 8 * un + (uvarnumber_T)(*ptr - '0');
+	    if (un < UVARNUM_MAX / 8 ||
+		    (un == UVARNUM_MAX / 8 && digit <= UVARNUM_MAX % 8))
+		un = 8 * un + digit;
 	    else
 		un = UVARNUM_MAX;
 	    ++ptr;
@@ -1959,9 +1963,11 @@ vim_str2nr(
 	    n += 2;	    /* skip over "0x" */
 	while (vim_isxdigit(*ptr))
