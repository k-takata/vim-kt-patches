diff --git a/src/charset.c b/src/charset.c
--- a/src/charset.c
+++ b/src/charset.c
@@ -1927,9 +1927,11 @@ vim_str2nr(
 	    n += 2;	    /* skip over "0b" */
 	while ('0' <= *ptr && *ptr <= '1')
 	{
+	    uvarnumber_T    digit = (uvarnumber_T)(*ptr - '0');
 	    /* avoid ubsan error for overflow */
