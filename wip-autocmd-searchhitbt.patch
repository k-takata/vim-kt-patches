diff --git a/runtime/doc/autocmd.txt b/runtime/doc/autocmd.txt
index eba6e4354..ec33e4049 100644
--- a/runtime/doc/autocmd.txt
+++ b/runtime/doc/autocmd.txt
@@ -423,6 +423,9 @@ Name			triggered by ~
 |TextChangedT|		after a change was made to the text in Terminal mode
 |TextYankPost|		after text has been yanked or deleted
 
+|SearchHitBottom|	when searching hit the bottom of the file
+|SearchHitTop|		when searching hit the top of the file
+
 |SafeState|		nothing pending, going to wait for the user to type a
 			character
 |SafeStateAgain|	repeated SafeState
@@ -1183,6 +1186,22 @@ SafeStateAgain			Like SafeState but after processing any
 				triggered often, don't do something that takes
 				time.
 
+							*SearchHitBottom*
+SearchHitBottom			When searching hit the bottom of the file.
+							*SearchHitTop*
+SearchHitTop			When searching hit the top of the file.
+				This is a simple example to show a popup when
+				hitting the top or the bottom: >
+	if exists("##SearchHitTop")
+	  augroup SearchHit
+	    au!
+	    au SearchHitTop * call popup_notification(
+		\ $"Search hit top: {@/}", #{time: 2000})
+	    au SearchHitBottom * call popup_notification(
+		\ $"Search hit bottom: {@/}", #{time: 2000})
+	  augroup END
+	endif
+<
 							*SessionLoadPre*
 SessionLoadPre			Before loading the session file created using
 				the |:mksession| command.
