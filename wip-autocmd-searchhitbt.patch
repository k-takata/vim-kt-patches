diff --git a/src/search.c b/src/search.c
index bb85873dc..8a9e78ee4 100644
--- a/src/search.c
+++ b/src/search.c
@@ -1125,9 +1125,16 @@ searchit(
 	     * written.
 	     */
 	    if (dir == BACKWARD)    // start second loop at the other end
+	    {
 		lnum = buf->b_ml.ml_line_count;
+		apply_autocmds(EVENT_SEARCHHITTOP, NULL, NULL, FALSE, curbuf);
+	    }
 	    else
+	    {
 		lnum = 1;
+		apply_autocmds(EVENT_SEARCHHITBOTTOM, NULL, NULL, FALSE,
+								      curbuf);
+	    }
 	    if (!shortmess(SHM_SEARCH)
 		    && shortmess(SHM_SEARCHCOUNT)
 		    && (options & SEARCH_MSG))
