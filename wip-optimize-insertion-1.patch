diff --git a/src/change.c b/src/change.c
--- a/src/change.c
+++ b/src/change.c
@@ -1184,6 +1184,7 @@ ins_str(char_u *s)
     char_u	*oldp, *newp;
     int		newlen = (int)STRLEN(s);
     int		oldlen;
+    int		new_size;
     colnr_T	col;
     linenr_T	lnum = curwin->w_cursor.lnum;
 
@@ -1194,16 +1195,28 @@ ins_str(char_u *s)
     oldp = ml_get(lnum);
     oldlen = (int)ml_get_len(lnum);
 
-    newp = alloc(oldlen + newlen + 1);
-    if (newp == NULL)
-	return;
-    if (col > 0)
+    new_size = oldlen + newlen + 1;
+    if ((curbuf->b_ml.ml_flags & (ML_ALLOCATED)) == 0
+	    || (curbuf->b_ml.ml_line_size < new_size))
+    {
+	new_size = new_size * 3 / 2;
+	newp = alloc(new_size);
+	if (newp == NULL)
+	    return;
+	curbuf->b_ml.ml_line_size = new_size;
+    }
+    else
+	newp = oldp;
+
+    if (col > 0 && newp != oldp)
 	mch_memmove(newp, oldp, (size_t)col);
+    mch_memmove(newp + col + newlen, oldp + col, (size_t)(oldlen - col + 1));
     mch_memmove(newp + col, s, (size_t)newlen);
-    mch_memmove(newp + col + newlen, oldp + col, (size_t)(oldlen - col + 1));
-    ml_replace(lnum, newp, FALSE);
+    ml_replace_len(lnum, newp, oldlen + newlen, FALSE, FALSE);
     inserted_bytes(lnum, col, newlen);
     curwin->w_cursor.col += newlen;
+    if ((newp != oldp) && (newp == curbuf->b_ml.ml_line_ptr))
+	curbuf->b_ml.ml_flags |= ML_ALLOCATED;
 }
 
