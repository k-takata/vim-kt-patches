 /*
+ * Check if variable "name" is a local variable or an argument.
+ * If it is a local variable, store it to the "eval_lvars_dict" dict.
+ * If it is an argument, store it to the "eval_avars_dict" dict.
+ */
+    static void
+check_vars(
+    char_u	*name,
+    int		len)		/* length of "name" */
+{
+    int		cc;
+    char_u	*varname;
+    hashtab_T	*ht;
+
+    /* truncate the name, so that we can use strcmp() */
+    cc = name[len];
+    name[len] = NUL;
+
+    ht = find_var_ht(name, &varname);
+    if ((ht == get_funccal_local_ht()) && (eval_lvars_dict != NULL))
+    {
+	dictitem_T  *di, *di2;
+
+	di = find_var_in_ht(ht, *name, varname, FALSE);
+	if (di != NULL
+		&& dict_find(eval_lvars_dict, DI2HIKEY(di), -1) == NULL)
+	{
+	    di2 = dictitem_copy(di);
+	    if (di2 != NULL)
+		dict_add(eval_lvars_dict, di2);
+	}
+    }
+    else if ((ht == get_funccal_args_ht()) && (eval_avars_dict != NULL))
+    {
+	dictitem_T  *di, *di2;
+
+	di = find_var_in_ht(ht, *name, varname, FALSE);
+	if (di != NULL
+		&& dict_find(eval_avars_dict, DI2HIKEY(di), -1) == NULL)
+	{
+	    di2 = dictitem_copy(di);
+	    if (di2 != NULL)
+		dict_add(eval_avars_dict, di2);
+	}
+    }
+
+    name[len] = cc;
+
+    return;
+}
+
