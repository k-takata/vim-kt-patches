 }
 
+    static void
+copy_lvars(dict_T *to, dict_T *from)
+{
+    dictitem_T	*di;
+    int		todo;
+    hashitem_T	*hi;
+
+    if (from == NULL)
+	return;
+
+    todo = (int)from->dv_hashtab.ht_used;
+    for (hi = from->dv_hashtab.ht_array; todo > 0; ++hi)
+    {
+	if (!HASHITEM_EMPTY(hi))
+	{
+	    --todo;
+
+	    if (!HASHITEM_EMPTY(hash_find(&to->dv_hashtab, hi->hi_key)))
+		continue;
+	    di = dictitem_alloc(hi->hi_key);
+	    if (di == NULL)
+		break;
+	    copy_tv(&HI2DI(hi)->di_tv, &di->di_tv);
+	    if (dict_add(to, di) == FAIL)
+	    {
+		dictitem_free(di);
+		break;
+	    }
+	}
+    }
+}
