 endfunction
@@ -237,13 +239,47 @@ endfunction
 function! Test_closure_unlet()
   function! s:foo()
     let x = 1
-    function! s:bar() closure
+    function! Bar() closure
       unlet x
     endfunction
-    call s:bar()
+    call Bar()
     return l:
   endfunction
 
   call assert_false(has_key(s:foo(), 'x'))
   call test_garbagecollect_now()
 endfunction
+
+function! Test_closure_redefine()
+  function! s:foo()
+    function Bar() closure
+    endfunction
+    function Bar() closure
+    endfunction
+  endfunction
+
+  call assert_fails('call s:foo()', 'E707:')
+
+  function! s:foo()
+    function Bar() closure
+    endfunction
+    function! Bar() closure
+    endfunction
+  endfunction
+
+  call s:foo()	" no error
+endfunction
+
+function! Test_closure_nonlocal()
+  function! s:foo1()
+    function! s:bar() closure
+    endfunction
+  endfunction
+  function! s:foo2()
+    function! g:Bar() closure
+    endfunction
+  endfunction
+
+  call assert_fails('call s:foo1()', 'Exxx:')
+  call assert_fails('call s:foo2()', 'Exxx:')
+endfunction
