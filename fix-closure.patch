+/*
+ * Check if the function "name" is an unnamed function.
+ * Return TRUE if it is an unnamed function, FALSE otherwise.
+ */
+    static int
+is_unnamed_func(char_u *name)
+{
+    if (name == NULL)
+	return FALSE;
+    if (isdigit(*name))
+	return TRUE;
+    else if (STRNCMP(name, "<lambda>", 8) == 0)
+	return TRUE;
+    else if (STRNCMP(name, "<closure>", 9) == 0)
+	return TRUE;
+    return FALSE;
+}
